# backend 앱 환경 — compose 가 env_file 로 backend 컨테이너에 주입한다.
#   복사해서 .env 로:   cp backend/.env.example backend/.env   후 값 채우기.
#   ※ .env 는 gitignore(시크릿) — 커밋 안 됨. `git checkout`/`switch` 로도 지워지지 않는다.
#   ※ 포트·동시인원·redis 비번 등 compose 노브는 여기가 아니라 infra/docker-compose/.env 에.
#
# 여기 두는 이유: LLM_PROVIDER / ANTHROPIC_API_KEY 는 compose 의 environment 블록에
# 정의돼 있지 않다(정의하면 env_file 을 덮어쓰므로 일부러 뺌). 그래서 이 파일이 유일한 출처.

# ── LLM (copilot) ────────────────────────────────────────────────
LLM_PROVIDER=anthropic                # anthropic | ollama | internal
ANTHROPIC_API_KEY=sk-ant-...          # LLM_PROVIDER=anthropic 일 때 필수

# ── 내부망 vLLM (선택, LLM_PROVIDER 보다 우선) ───────────────────
INTERNAL_NETWORK=false                # true 면 내부망 vLLM(Keycloak 게이트) 사용
INTERNAL_LLM_MODEL=gemma4             # gemma4 | gptoss120b   (INTERNAL_NETWORK=true 일 때)

# ── 로컬 ollama (선택, LLM_PROVIDER=ollama) ──────────────────────
# OLLAMA_BASE_URL=http://ollama:11434

# 그 외 BACKEND_* (DB 경로·쿠키·OIDC·시드 등)는 compose 의 environment 블록에서 지정됨.
# 필요 시 여기서 override:  예) BACKEND_COOKIE_SECURE=true   # HTTPS 운영 시 권장
