# docker compose 변수 치환(${...})용 환경 파일.
#   복사해서 .env 로 만든 뒤 값을 채운다:   cp .env.example .env
#   ※ .env 는 gitignore(시크릿) — 커밋되지 않으며, `git checkout`/`switch` 로도 지워지지 않는다.
#   ※ LLM 키 등 "backend 앱" 시크릿은 여기가 아니라 backend/.env 에 둔다(역할이 다름).
#
# 값이 제대로 먹었는지 확인:
#   docker compose -f compose.prod.yml config | grep -iE 'PORTAL_PORT|MEM_LIMIT|ACTIVE_SERVER'

# ── 공통 (dev/prod) ──────────────────────────────────────────────
REDIS_PASSWORD=changeme               # prod 는 반드시 바꿀 것
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING

# 자격증명 암호화용 고정 Fernet 키. 비워두면 부팅마다 임시 키 → 재시작 후 기존
# 암호문 복호화 불가. prod 는 고정값 필수.  생성:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKEND_CREDENTIAL_KEY=

# 셀 단위 인라인 편집용 경량 모델(copilot)
COPILOT_EDIT_MODEL=claude-haiku-4-5-20251001

# ── prod (compose.prod.yml) ──────────────────────────────────────
PORTAL_PORT=5500                      # 외부 노출 포트(온프레미스 서버가 여는 포트)

# JupyterHub 사용자별 격리(DockerSpawner). 규칙: 동시인원 × 1인당RAM ≤ (전체RAM − ~2.5GB).
JUPYTERHUB_ACTIVE_SERVER_LIMIT=3      # 동시 접속(떠 있는 사용자 서버) 상한 (0=무제한)
JUPYTERHUB_USER_MEM_LIMIT=1.5G        # 1인당 RAM 상한. 단위는 대문자(500M, 2G). 500M 로 줄이면 8GB 기준 ~10명
JUPYTERHUB_USER_CPU_LIMIT=2.0         # 1인당 CPU 코어 상한

# ── dev (compose.yml) 전용 ───────────────────────────────────────
OLLAMA_MODEL=qwen2.5-coder:7b         # 로컬 LLM(--profile llm) 사용 시
BACKEND_OIDC_ENABLED=false            # Keycloak SSO 끔(기본: 쿠키 인증)
# BACKEND_OIDC_ISSUER=http://keycloak:8080/realms/dataplatform
# BACKEND_OIDC_AUDIENCE=
